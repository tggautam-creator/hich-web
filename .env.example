# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Supabase — find these in your project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Places API (Week 3 — Destination Search)
VITE_GOOGLE_PLACES_KEY=your-google-places-key

# Stripe publishable key (Week 6 — Payments, test mode only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Server-side secrets — used in /server only, never exposed to the browser
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-key-here
FCM_SERVER_KEY=your-fcm-server-key
QR_HMAC_SECRET=a-long-random-secret-string
