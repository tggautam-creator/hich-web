# Copy this file to .env and fill in your values.
# Never commit .env to git.
#
# ── ENVIRONMENT ISOLATION (read this first) ──────────────────────────────
# Local development MUST point at the dev Supabase project + test Stripe
# keys. Pointing local at the prod Supabase project corrupts the live
# user.stripe_*_id columns by overwriting them with test-mode IDs — see
# the post-mortem in /Users/.../scenario-2-stripe-purring-hollerith.md.
# Two simple rules:
#   1. VITE_SUPABASE_URL points at tago-dev (NOT the prod project).
#   2. STRIPE_SECRET_KEY starts with sk_test_ (NOT sk_live_).
# The server refuses to boot if NODE_ENV=production AND key is sk_test_.
# The client paints a yellow "Sandbox" banner whenever the publishable
# key is pk_test_, so a test session can never be confused with prod.

# Supabase — find these in your project Settings → API
VITE_SUPABASE_URL=https://your-DEV-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-DEV-anon-key-here

# Google Places API (Week 3 — Destination Search)
VITE_GOOGLE_PLACES_KEY=your-google-places-key

# Google Maps JavaScript API — maps, geocoding, directions
VITE_GOOGLE_MAPS_KEY=your-google-maps-key

# Stripe publishable key (Week 6 — Payments, test mode only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Firebase — find these in Firebase Console → Project Settings → General
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_VAPID_KEY=your-vapid-key

# Server-side secrets — used in /server only, never exposed to the browser
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-key-here
QR_HMAC_SECRET=a-long-random-secret-string

# auto.dev — vehicle plate-to-VIN lookup (Scale plan required)
AUTO_DEV_API_KEY=sk_ad_your-key-here
